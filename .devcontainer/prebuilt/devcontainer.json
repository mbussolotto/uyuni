{
	"name": "Prebuilt",
    "dockerComposeFile": "docker-compose.yml",
    "service": "uyuni-code",
    "workspaceFolder": "/workspaces/uyuni-code",

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	"remoteUser": "root",
    "postAttachCommand": "mv /repository /workspaces/uyuni-code/uyuni/java/buildconf/ivy/ && mkdir -p /workspaces/uyuni-code/uyuni/java/lib && mv /uyuni-lib/* /workspaces/uyuni-code/uyuni/java/lib/"
}
